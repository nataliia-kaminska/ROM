APP_ENV=local
DEBUG=false
DATABASE_URL=sqlite:///./research_matcher.db
REDIS_URL=redis://localhost:6379/0
WEBSOCKET_REDIS_ENABLED=false
WEBSOCKET_NOTIFICATIONS_CHANNEL=notifications:realtime
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_OPPORTUNITY_INDEX=research_opportunities
ELASTICSEARCH_INDEX_ON_IMPORT=true
SCHEDULER_TICK_SECONDS=60
SOURCE_SYNC_INTERVAL_SECONDS=21600
SOURCE_SYNC_LIMIT=25
SCHEDULED_GRANTS_GOV_KEYWORDS=["research","fellowship"]
REMINDER_SCAN_INTERVAL_SECONDS=3600
EMBEDDING_DIMENSIONS=128
EMBEDDING_PROVIDER=hash
EMBEDDING_AUTO_INSTALL=false
EMBEDDING_LOCAL_FILES_ONLY=false
EMBEDDING_PREWARM_ON_STARTUP=false
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
OPPORTUNITY_EMBEDDING_ON_IMPORT=true
SEMANTIC_CANDIDATE_LIMIT=250
SEMANTIC_SCORE_WEIGHT=0.35
ELIGIBILITY_SCORE_WEIGHT=0.35
DEADLINE_SCORE_WEIGHT=0.15
USER_HISTORY_SCORE_WEIGHT=0.15
AUTO_CREATE_TABLES=true
CORS_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
AUTH_REFRESH_COOKIE_NAME=rom_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=20
ORCID_BASE_URL=https://pub.orcid.org/v3.0
ORCID_OAUTH_ENABLED=false
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://127.0.0.1:8000/auth/orcid/callback
ORCID_AUTHORIZE_URL=https://orcid.org/oauth/authorize
ORCID_TOKEN_URL=https://orcid.org/oauth/token
ORCID_OAUTH_SCOPE=/authenticate
OAUTH_STATE_EXPIRE_MINUTES=10
OPENALEX_BASE_URL=https://api.openalex.org
EXTERNAL_SOURCE_ALLOWED_HOSTS=[]
EXTERNAL_SOURCE_MAX_BYTES=2000000
EXTERNAL_SOURCE_RESOLVE_HOSTS=true
EMAIL_PROVIDER=smtp
EMAIL_FROM=Research Matcher <noreply@example.local>
FRONTEND_BASE_URL=http://127.0.0.1:3000
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
WEEKLY_DIGEST_INTERVAL_SECONDS=604800
HIGH_MATCH_ALERT_INTERVAL_SECONDS=3600
ADVISOR_PROVIDER=deterministic
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ADVISOR_LOCAL_BASE_URL=http://localhost:11434/v1
ADVISOR_LOCAL_MODEL=llama3.1:8b
ADVISOR_TIMEOUT_SECONDS=20
OPPORTUNITY_EXTRACTION_PROVIDER=deterministic
OPPORTUNITY_EXTRACTION_MODEL=
OPPORTUNITY_EXTRACTION_TIMEOUT_SECONDS=20
OPPORTUNITY_PAGE_ENRICHMENT_ENABLED=true
OPPORTUNITY_PAGE_ENRICHMENT_MAX_CHARS=5000
OPPORTUNITY_PAGE_ENRICHMENT_TIMEOUT_SECONDS=12
PROFILE_ENRICHMENT_AUTO_OPENALEX=false
PROFILE_ENRICHMENT_PROVIDER=deterministic
PROFILE_ENRICHMENT_MODEL=
PROFILE_ENRICHMENT_MAX_WORKS=20
PROFILE_ENRICHMENT_TIMEOUT_SECONDS=20
