APP_ENV=local
DEBUG=false
DATABASE_URL=sqlite:///./research_matcher.db
REDIS_URL=redis://localhost:6379/0
WEBSOCKET_REDIS_ENABLED=false
WEBSOCKET_NOTIFICATIONS_CHANNEL=notifications:realtime
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_OPPORTUNITY_INDEX=research_opportunities
SCHEDULER_TICK_SECONDS=60
SOURCE_SYNC_INTERVAL_SECONDS=21600
SOURCE_SYNC_LIMIT=25
SCHEDULED_GRANTS_GOV_KEYWORDS=["research","fellowship"]
REMINDER_SCAN_INTERVAL_SECONDS=3600
EMBEDDING_DIMENSIONS=128
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_CANDIDATE_LIMIT=250
SEMANTIC_SCORE_WEIGHT=0.35
ELIGIBILITY_SCORE_WEIGHT=0.35
DEADLINE_SCORE_WEIGHT=0.15
USER_HISTORY_SCORE_WEIGHT=0.15
AUTO_CREATE_TABLES=true
CORS_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]
LOG_LEVEL=INFO
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ORCID_BASE_URL=https://pub.orcid.org/v3.0
OPENALEX_BASE_URL=https://api.openalex.org
EMAIL_PROVIDER=console
EMAIL_FROM=Research Matcher <noreply@example.local>
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
WEEKLY_DIGEST_INTERVAL_SECONDS=604800
HIGH_MATCH_ALERT_INTERVAL_SECONDS=3600
ADVISOR_PROVIDER=deterministic
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ADVISOR_LOCAL_BASE_URL=http://localhost:11434/v1
ADVISOR_LOCAL_MODEL=llama3.1:8b
ADVISOR_TIMEOUT_SECONDS=20
