# Full-feature local configuration for running the API/worker from Windows PowerShell.
# Use this when PostgreSQL, Redis, and Elasticsearch are exposed on localhost by Docker Compose,
# but FastAPI/RQ are started from .venv instead of inside containers.

APP_ENV=local
DEBUG=true
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=false

# PostgreSQL + pgvector exposed from Docker Compose to the host.
DATABASE_URL=postgresql+psycopg://research:research@127.0.0.1:5432/research_matcher

# Redis powers RQ jobs, scheduler locks, and WebSocket pub/sub.
REDIS_URL=redis://127.0.0.1:6379/0
WEBSOCKET_REDIS_ENABLED=true
WEBSOCKET_NOTIFICATIONS_CHANNEL=notifications:realtime

# Elasticsearch full-text search exposed from Docker Compose to the host.
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_OPPORTUNITY_INDEX=research_opportunities

# Workers and scheduler.
SCHEDULER_TICK_SECONDS=60
SOURCE_SYNC_INTERVAL_SECONDS=21600
SOURCE_SYNC_LIMIT=25
SCHEDULED_GRANTS_GOV_KEYWORDS=["research","fellowship","postdoc","climate","health"]
REMINDER_SCAN_INTERVAL_SECONDS=3600
WEEKLY_DIGEST_INTERVAL_SECONDS=604800
HIGH_MATCH_ALERT_INTERVAL_SECONDS=3600

# Embeddings. Use sentence-transformers for local model embeddings.
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_AUTO_INSTALL=true
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
SEMANTIC_CANDIDATE_LIMIT=250
SEMANTIC_SCORE_WEIGHT=0.35
ELIGIBILITY_SCORE_WEIGHT=0.35
DEADLINE_SCORE_WEIGHT=0.15
USER_HISTORY_SCORE_WEIGHT=0.15

# API and security.
APP_NAME=Research Opportunity Matcher
CORS_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Integrations.
ORCID_BASE_URL=https://pub.orcid.org/v3.0
OPENALEX_BASE_URL=https://api.openalex.org

# Advisor generation. Groq is used when ADVISOR_PROVIDER=groq.
ADVISOR_PROVIDER=groq
GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
ADVISOR_TIMEOUT_SECONDS=20
OPPORTUNITY_EXTRACTION_PROVIDER=groq
OPPORTUNITY_EXTRACTION_MODEL=llama-3.1-8b-instant
OPPORTUNITY_EXTRACTION_TIMEOUT_SECONDS=20
PROFILE_ENRICHMENT_AUTO_OPENALEX=true
PROFILE_ENRICHMENT_PROVIDER=groq
PROFILE_ENRICHMENT_MODEL=llama-3.1-8b-instant
PROFILE_ENRICHMENT_MAX_WORKS=20
PROFILE_ENRICHMENT_TIMEOUT_SECONDS=20

# Optional local LLM fallback.
ADVISOR_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
ADVISOR_LOCAL_MODEL=llama3.1:8b

# Email delivery. Console is safest for local; switch to smtp for real delivery.
EMAIL_PROVIDER=console
EMAIL_FROM=Research Matcher <noreply@example.local>
FRONTEND_BASE_URL=http://127.0.0.1:3000
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_VERIFICATION_EXPIRE_HOURS=24
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
